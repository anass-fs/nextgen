# Copier vers .env et adapter les valeurs

DEBUG=True
SECRET_KEY=change-me-to-a-long-random-string-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS (origines autorisées, séparées par des virgules ; vide = tout en dev)
CORS_ALLOWED_ORIGINS=

# Badge « Top Developer » — score minimal
TOP_DEVELOPER_MIN_SCORE=100

# Production / Docker — MySQL
MYSQL_DATABASE=devconnect
MYSQL_USER=devconnect
MYSQL_PASSWORD=devconnect
MYSQL_HOST=db
MYSQL_PORT=3306
